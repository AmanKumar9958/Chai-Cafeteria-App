{
  "expo": {
    "name": "Chai Cafeteria",
    "slug": "chai-cafeteria",
    "version": "4.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/chai-cafeteria-icon.png",
    "scheme": "chai-cafeteria",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.solostackdev.chaicafeteria"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFF7ED",
        "foregroundImage": "./assets/images/chai-cafeteria-icon.png"
      },
      "newArchEnabled": true,
      "versionCode": 12,
      "package": "com.solostackdev.chaicafeteria",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/chai-cafeteria-icon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#FFF7ED"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#E8751A"
        }
      ],
      "expo-web-browser"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "20762fb1-607d-4174-87a9-85f8dd83bc64"
      }
    }
  }
}
